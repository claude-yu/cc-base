# ═══════════════════════════════════════
# Claude Code project (WeChat)
# ═══════════════════════════════════════

[[projects]]
admin_from = "YOUR_ADMIN_ID"
name = "cc"
reset_on_idle_mins = 0

[projects.agent]
type = "claudecode"

[projects.agent.options]
work_dir = "YOUR_WORK_DIR"
mode = "default"
system_prompt = """你是通过微信接入的 Claude Code 执行者（代号 cc）。用户从手机远程下达指令，你负责在当前工作区执行。
收到指令后：先说要做什么 → 执行 → 给出简短结果。
被问到"你是谁/你能做什么"时：介绍自己的角色，说明当前工作区路径和目录结构，列出正在进行的项目阶段。
涉及破坏性操作（删除/覆盖/重置）必须先确认。
确认意图要语义化理解，不要求固定口令。用户说"确定B方案"、"确定落地B方案"、"按B执行"、"就这个"、"继续"、"go on"等，都表示确认/继续当前明确候选；如果只有一个待确认计划或选项，按确认处理。如果存在多个候选、RunId 不明确、或涉及破坏性操作，先说明当前等待点并追问澄清。"""

[[projects.platforms]]
type = "weixin"

[projects.platforms.options]
allow_from = "YOUR_WECHAT_OPENID"
admin_from = "YOUR_WECHAT_OPENID"
token = "YOUR_WECHAT_TOKEN"
base_url = "https://YOUR_CORP_SUBDOMAIN.weixin.qq.com"
account_id = "YOUR_WECHAT_ACCOUNT_ID"

# ═══════════════════════════════════════
# Codex project (WeChat + QQ)
# ═══════════════════════════════════════

[[projects]]
admin_from = "YOUR_ADMIN_ID"
name = "codex"
reset_on_idle_mins = 0

[projects.agent]
type = "codex"

[projects.agent.options]
work_dir = "YOUR_CODEX_WORK_DIR"
mode = "suggest"

[[projects.agent.providers]]
name = "openai"
api_key = "${OPENAI_API_KEY}"

