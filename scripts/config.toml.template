# cc-connect config.toml template
# Copy this file and fill in your platform credentials.
# Source location: <project>/cc-connect/config.toml
# Deploy location: ~/.cc-connect/config.toml (auto-synced by start.ps1)

language = "zh"

[log]
level = "info"

# ═══════════════════════════════════════
# Controller pipeline commands
# ═══════════════════════════════════════
# Paths below assume: <project>/controller/bin/*.ps1
# Replace YOUR_PROJECT_ROOT with your actual project root.

[[commands]]
name = "计划审查"
description = "让 controller 生成计划并调用 Codex 审查，不执行"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\invoke-controller-command.ps1 -CommandName 计划审查 -Real YOUR_PROJECT_ROOT\\controller\\bin\\submit-plan-review.ps1 {{args}}"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "review-status"
description = "Show async plan-review run status or result"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\show-plan-review.ps1 -RunId \"{{args}}\""
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "latest-review"
description = "Show latest plan-review run"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\show-plan-review.ps1"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "md状态检查"
description = "只读采集工作目录的文件清单和 log tail，不执行"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\collect-md-status.ps1 \"{{args}}\""
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "修复controller"
description = "CC 直接修复 controller/cc-connect 基础设施报错，不走 Codex 审查"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\fix-controller.ps1 {{args}}"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "批准执行"
description = "执行已通过 Codex APPROVE 的 controller run"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\execute-approved.ps1 -RunId \"{{args}}\""
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "人工批准执行"
description = "执行用户人工接受的 controller run（需 manual-approval.md）"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\execute-manual-approved.ps1 -RunId \"{{args}}\""
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "质询计划"
description = "Grill-Me 模式逐条质询最近的计划审查结果"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\grill-plan.ps1 {{args}}"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "学习状态"
description = "查看 chat-instinct 学习统计（observations + instincts）"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\instinct-status.ps1"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "进化习惯"
description = "分析 observations 并生成进化候选（不自动写 skill）"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\evolve-instincts.ps1"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "问codex"
description = "异步询问 Codex，完成后自动回传结果（Go binary）"
exec = "YOUR_PROJECT_ROOT\\controller\\cc-controller.exe ask-codex {{args}}"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "codex结果"
description = "查看 Codex ask run 状态或结果"
exec = "YOUR_PROJECT_ROOT\\controller\\cc-controller.exe show {{args}}"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "问cc"
description = "Session-aware CC 对话（别名保持，实际走 /cc 通道）"
exec = "YOUR_PROJECT_ROOT\\controller\\cc-controller.exe exec-cc --text \"{{args}}\" --session default"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "cc结果"
description = "查看 CC ask run 状态或结果"
exec = "YOUR_PROJECT_ROOT\\controller\\cc-controller.exe show {{args}}"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "自动回传"
description = "开关计划审查完成后是否自动推回聊天窗口"
exec = "powershell -NoProfile -ExecutionPolicy Bypass -File YOUR_PROJECT_ROOT\\controller\\bin\\auto-callback-toggle.ps1 {{args}}"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "取消任务"
description = "取消正在运行的任务（/取消任务 <RunId>，不传 RunId 自动取消最近任务）"
exec = "YOUR_PROJECT_ROOT\\controller\\cc-controller.exe cancel {{args}}"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "cc"
description = "Session-aware CC 对话（自动判断模式：advice/readonly/execute_request）"
exec = "YOUR_PROJECT_ROOT\\controller\\cc-controller.exe exec-cc --auto --text \"{{args}}\" --session default"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "执行"
description = "执行已确认的任务（/执行 RunId，启动执行型 runner）"
exec = "YOUR_PROJECT_ROOT\\controller\\cc-controller.exe execute {{args}}"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "项目"
description = "查看当前工作项目信息"
exec = "YOUR_PROJECT_ROOT\\controller\\cc-controller.exe project"
work_dir = "YOUR_PROJECT_ROOT\\controller"

[[commands]]
name = "切项目"
description = "切换到指定项目（/切项目 work-15）"
exec = "YOUR_PROJECT_ROOT\\controller\\cc-controller.exe switch {{args}}"
work_dir = "YOUR_PROJECT_ROOT\\controller"

